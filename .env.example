# ── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/hagi_shop"

# ── Stripe (Server-Side-Redirect — Publishable Key wird NICHT benötigt) ──────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── URLs ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://hagi-shop.de"  # TODO: Domain nach Klärung eintragen

# ── Resend (E-Mail) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM="Hagi Teppiche <bestellungen@hagi-shop.de>"  # TODO: Domain anpassen

# ── Admin ────────────────────────────────────────────────────────────────────
# Einfacher Admin-Schutz: statisches Passwort als HTTP-Header
ADMIN_PASSWORD="sicheres_passwort_hier_eintragen"

# ── Bilder-Upload ────────────────────────────────────────────────────────────
# Option A: Cloudinary (empfohlen für Produktbilder)
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# Option B: Lokaler Upload in /public/uploads/ (einfacher, kein CDN)
# Kein ENV nötig — Files landen direkt im Container
