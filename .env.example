# ── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/hagi_shop"

# ── Stripe (Server-Side-Redirect — Publishable Key wird NICHT benötigt) ──────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── URLs ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://hagi-shop.de"  # TODO: Domain nach Klärung eintragen

# ── Resend (E-Mail) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM="Hagi Teppiche <bestellungen@hagi-shop.de>"  # TODO: Domain anpassen

# ── Admin Bootstrap (einmalig für scripts/create-admin.ts) ───────────────────
# Werden NUR vom Bootstrap-Script gelesen, nicht zur Laufzeit.
ADMIN_EMAIL="hagi@hagi-shop.de"
ADMIN_PASSWORD="dein-starkes-passwort-hier"
ADMIN_NAME="Hagi"

# ── Cron (Coolify-Cron alle 15 Min auf /api/cron/cleanup) ────────────────────
CRON_SECRET="generate_with_openssl_rand_base64_32"

# ── Steuer-Modus (PFLICHT in Production) ─────────────────────────────────────
# small_business = § 19 UStG Kleinunternehmer (0% USt)
# standard       = Regelbesteuerung (19% DE Standard) — erfordert COMPANY_VAT_ID
TAX_MODE="small_business"

# ── Firmenstammdaten für Rechnungen (§ 14 UStG) ──────────────────────────────
COMPANY_NAME="Hagi Teppiche"
COMPANY_STREET="Egilolfstraße 41"
COMPANY_CITY="70599 Stuttgart"
COMPANY_VAT_ID=""          # PFLICHT bei TAX_MODE=standard
COMPANY_TAX_NUMBER=""      # Alternative zur USt-ID
COMPANY_EMAIL="info@hagi-shop.de"
COMPANY_PHONE="+49 711 ..."
COMPANY_IBAN=""            # PFLICHT in Production (auf Rechnung)

# ── Bilder ───────────────────────────────────────────────────────────────────
# Aktuell: Produkt-Bilder werden als externe URLs (z.B. Cloudinary, S3) im
# Admin-Form eingetragen — keine Server-Side-Integration nötig.
# Wenn später echte Upload-API: hier Cloudinary-Keys ergänzen.
